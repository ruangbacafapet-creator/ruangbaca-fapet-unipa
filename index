<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ruang Baca Universitas Papua — Layanan Karya Ilmiah</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Source+Sans+3:wght@300;400;600&family=Courier+Prime:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --hijau: #1a5c38;
    --hijau-muda: #2d8653;
    --emas: #c8941a;
    --emas-muda: #e8b83a;
    --krem: #f5f0e8;
    --krem-gelap: #e8e0d0;
    --hitam: #1a1a1a;
    --putih: #fdfaf5;
    --abu: #6b6b6b;
    --merah: #b53a2a;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Source Sans 3', sans-serif;
    background: var(--putih);
    color: var(--hitam);
    overflow-x: hidden;
  }

  /* === NAVBAR === */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--hijau);
    border-bottom: 3px solid var(--emas);
    padding: 0 40px;
    display: flex; align-items: center; justify-content: space-between;
    height: 68px;
  }
  .nav-brand {
    display: flex; align-items: center; gap: 14px;
  }
  .nav-logo {
    width: 44px; height: 44px;
    background: var(--emas);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Playfair Display', serif;
    font-weight: 900; font-size: 18px; color: var(--hijau);
  }
  .nav-title {
    font-family: 'Playfair Display', serif;
    font-size: 15px; font-weight: 700;
    color: var(--putih);
    line-height: 1.2;
  }
  .nav-sub { font-size: 11px; color: var(--emas-muda); font-weight: 300; letter-spacing: 1px; }
  .nav-links { display: flex; gap: 6px; }
  .nav-links a {
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    font-size: 13px;
    padding: 8px 14px;
    border-radius: 4px;
    transition: all 0.2s;
    font-weight: 600;
    letter-spacing: 0.3px;
  }
  .nav-links a:hover { background: rgba(255,255,255,0.15); color: var(--emas-muda); }
  .nav-links a.active { background: var(--emas); color: var(--hijau); }

  /* === HERO === */
  .hero {
    margin-top: 68px;
    min-height: 92vh;
    background: linear-gradient(135deg, var(--hijau) 0%, #0d3d24 60%, #1a5c38 100%);
    position: relative;
    overflow: hidden;
    display: flex; align-items: center;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image: repeating-linear-gradient(
      0deg, transparent, transparent 60px,
      rgba(255,255,255,0.03) 60px, rgba(255,255,255,0.03) 61px
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 60px,
      rgba(255,255,255,0.03) 60px, rgba(255,255,255,0.03) 61px
    );
  }
  .hero-ornament {
    position: absolute; right: -80px; top: -80px;
    width: 500px; height: 500px;
    border: 2px solid rgba(200, 148, 26, 0.2);
    border-radius: 50%;
  }
  .hero-ornament::after {
    content: '';
    position: absolute; inset: 40px;
    border: 2px solid rgba(200, 148, 26, 0.15);
    border-radius: 50%;
  }
  .hero-content {
    position: relative; z-index: 2;
    padding: 80px 80px;
    max-width: 780px;
    animation: fadeUp 0.8s ease both;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(200,148,26,0.2);
    border: 1px solid rgba(200,148,26,0.5);
    color: var(--emas-muda);
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 12px;
    font-family: 'Courier Prime', monospace;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 28px;
  }
  .hero-badge span { width: 6px; height: 6px; background: var(--emas); border-radius: 50%; animation: blink 1.5s infinite; }
  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(38px, 5vw, 62px);
    font-weight: 900;
    color: var(--putih);
    line-height: 1.1;
    margin-bottom: 24px;
  }
  .hero h1 em { color: var(--emas-muda); font-style: normal; }
  .hero p {
    color: rgba(255,255,255,0.75);
    font-size: 17px;
    line-height: 1.7;
    margin-bottom: 48px;
    max-width: 580px;
  }
  .hero-cta { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-primary {
    background: var(--emas);
    color: var(--hijau);
    padding: 14px 32px;
    border-radius: 4px;
    font-weight: 700;
    font-size: 14px;
    text-decoration: none;
    letter-spacing: 0.5px;
    transition: all 0.2s;
    border: none; cursor: pointer;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .btn-primary:hover { background: var(--emas-muda); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(200,148,26,0.4); }
  .btn-outline {
    border: 2px solid rgba(255,255,255,0.4);
    color: var(--putih);
    padding: 14px 32px;
    border-radius: 4px;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    transition: all 0.2s;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .btn-outline:hover { border-color: var(--putih); background: rgba(255,255,255,0.1); }

  .hero-stats {
    position: absolute; right: 80px; bottom: 60px;
    display: flex; gap: 40px;
    animation: fadeUp 0.8s 0.3s ease both;
  }
  .stat { text-align: center; }
  .stat-num { font-family: 'Playfair Display', serif; font-size: 36px; font-weight: 900; color: var(--emas); }
  .stat-label { font-size: 12px; color: rgba(255,255,255,0.6); letter-spacing: 1px; text-transform: uppercase; }

  /* === SECTIONS === */
  section { padding: 90px 80px; }
  .section-label {
    font-family: 'Courier Prime', monospace;
    font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
    color: var(--emas); margin-bottom: 12px;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 3vw, 42px);
    font-weight: 700; color: var(--hijau);
    margin-bottom: 16px; line-height: 1.2;
  }
  .section-desc { color: var(--abu); font-size: 16px; line-height: 1.7; max-width: 600px; }

  /* === LAYANAN CARDS === */
  #layanan { background: var(--krem); }
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px; margin-top: 48px;
  }
  .card {
    background: var(--putih);
    border-radius: 8px;
    padding: 36px 32px;
    border: 1px solid var(--krem-gelap);
    border-top: 4px solid var(--hijau);
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }
  .card::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0; height: 0;
    background: linear-gradient(to top, rgba(26,92,56,0.05), transparent);
    transition: height 0.3s;
  }
  .card:hover { transform: translateY(-6px); box-shadow: 0 20px 48px rgba(26,92,56,0.12); }
  .card:hover::after { height: 100%; }
  .card-icon {
    width: 56px; height: 56px;
    background: linear-gradient(135deg, var(--hijau), var(--hijau-muda));
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px; margin-bottom: 20px;
  }
  .card h3 { font-family: 'Playfair Display', serif; font-size: 20px; color: var(--hijau); margin-bottom: 12px; }
  .card p { color: var(--abu); font-size: 14px; line-height: 1.6; }
  .card-link {
    display: inline-flex; align-items: center; gap: 6px;
    margin-top: 20px; color: var(--emas); font-weight: 600; font-size: 13px;
    text-decoration: none; transition: gap 0.2s;
  }
  .card-link:hover { gap: 10px; }

  /* === UPLOAD SECTION === */
  #upload { background: var(--putih); }
  .upload-container {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 60px; margin-top: 48px; align-items: start;
  }
  .upload-info h3 { font-family: 'Playfair Display', serif; font-size: 24px; color: var(--hijau); margin-bottom: 16px; }
  .upload-info p { color: var(--abu); line-height: 1.7; margin-bottom: 24px; }
  .syarat-list { list-style: none; }
  .syarat-list li {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--krem-gelap);
    font-size: 14px; color: var(--hitam);
  }
  .syarat-list li::before {
    content: '✓';
    width: 22px; height: 22px;
    background: var(--hijau);
    color: white;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700;
    flex-shrink: 0; margin-top: 1px;
  }

  .upload-form-wrap {
    background: var(--krem);
    border-radius: 12px;
    padding: 40px;
    border: 1px solid var(--krem-gelap);
  }
  .upload-form-wrap h3 {
    font-family: 'Playfair Display', serif;
    font-size: 22px; color: var(--hijau);
    margin-bottom: 8px;
  }
  .upload-form-wrap > p { font-size: 13px; color: var(--abu); margin-bottom: 28px; }

  .form-group { margin-bottom: 20px; }
  .form-group label {
    display: block; font-size: 13px; font-weight: 600;
    color: var(--hitam); margin-bottom: 8px; letter-spacing: 0.3px;
  }
  .form-group label span { color: var(--merah); }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1.5px solid var(--krem-gelap);
    border-radius: 6px;
    font-size: 14px;
    font-family: 'Source Sans 3', sans-serif;
    background: var(--putih);
    color: var(--hitam);
    transition: border-color 0.2s;
    outline: none;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--hijau);
    box-shadow: 0 0 0 3px rgba(26,92,56,0.08);
  }
  .form-group textarea { resize: vertical; min-height: 90px; }

  .upload-zone {
    border: 2px dashed var(--krem-gelap);
    border-radius: 8px;
    padding: 32px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    background: var(--putih);
  }
  .upload-zone:hover { border-color: var(--hijau); background: rgba(26,92,56,0.03); }
  .upload-zone .icon { font-size: 36px; margin-bottom: 12px; }
  .upload-zone p { font-size: 14px; color: var(--abu); }
  .upload-zone strong { color: var(--hijau); }
  .upload-zone small { font-size: 12px; color: var(--abu); display: block; margin-top: 6px; }

  .form-note {
    background: rgba(26,92,56,0.07);
    border-left: 3px solid var(--hijau);
    padding: 12px 16px;
    border-radius: 0 6px 6px 0;
    font-size: 13px; color: var(--hijau);
    margin-bottom: 20px;
    line-height: 1.5;
  }

  .btn-submit {
    width: 100%;
    background: var(--hijau);
    color: var(--putih);
    padding: 14px;
    border: none;
    border-radius: 6px;
    font-size: 15px;
    font-weight: 700;
    font-family: 'Source Sans 3', sans-serif;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.5px;
  }
  .btn-submit:hover { background: var(--hijau-muda); transform: translateY(-1px); box-shadow: 0 8px 20px rgba(26,92,56,0.25); }

  /* === SOP SECTION === */
  #sop { background: var(--hijau); }
  #sop .section-label { color: var(--emas-muda); }
  #sop .section-title { color: var(--putih); }
  #sop .section-desc { color: rgba(255,255,255,0.7); }

  .sop-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 20px; margin-top: 48px; }
  .sop-card {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    padding: 32px;
    backdrop-filter: blur(4px);
    transition: all 0.3s;
  }
  .sop-card:hover { background: rgba(255,255,255,0.14); transform: translateY(-4px); }
  .sop-num {
    font-family: 'Courier Prime', monospace;
    font-size: 11px; letter-spacing: 2px;
    color: var(--emas-muda); margin-bottom: 12px;
  }
  .sop-card h3 { font-family: 'Playfair Display', serif; font-size: 20px; color: var(--putih); margin-bottom: 14px; }
  .sop-steps { list-style: none; }
  .sop-steps li {
    display: flex; gap: 12px;
    font-size: 13px; color: rgba(255,255,255,0.75);
    padding: 7px 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    line-height: 1.5;
  }
  .sop-steps li:last-child { border-bottom: none; }
  .step-n {
    background: var(--emas);
    color: var(--hijau);
    width: 20px; height: 20px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 700;
    flex-shrink: 0; margin-top: 1px;
  }

  .sop-download {
    margin-top: 48px;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 20px;
    background: rgba(200,148,26,0.15);
    border: 1px solid rgba(200,148,26,0.3);
    border-radius: 8px;
    padding: 28px 36px;
  }
  .sop-download p { color: var(--putih); font-size: 16px; }
  .sop-download p span { color: var(--emas-muda); font-weight: 600; }

  /* === KOLEKSI SECTION === */
  #koleksi { background: var(--krem); }
  .search-bar {
    display: flex; gap: 12px;
    margin: 40px 0 32px;
    max-width: 680px;
  }
  .search-bar input {
    flex: 1; padding: 14px 20px;
    border: 2px solid var(--krem-gelap);
    border-radius: 6px; font-size: 15px;
    font-family: 'Source Sans 3', sans-serif;
    outline: none; transition: border-color 0.2s;
    background: var(--putih);
  }
  .search-bar input:focus { border-color: var(--hijau); }
  .search-bar button {
    background: var(--hijau); color: white;
    border: none; padding: 14px 28px;
    border-radius: 6px; cursor: pointer;
    font-size: 14px; font-weight: 600;
    font-family: 'Source Sans 3', sans-serif;
    transition: background 0.2s;
  }
  .search-bar button:hover { background: var(--hijau-muda); }

  .filter-tabs { display: flex; gap: 8px; margin-bottom: 32px; flex-wrap: wrap; }
  .filter-tab {
    padding: 8px 20px; border-radius: 20px;
    border: 1.5px solid var(--krem-gelap);
    background: var(--putih); color: var(--abu);
    font-size: 13px; font-weight: 600; cursor: pointer;
    transition: all 0.2s;
  }
  .filter-tab.active, .filter-tab:hover {
    background: var(--hijau); color: white; border-color: var(--hijau);
  }

  .koleksi-table {
    width: 100%; border-collapse: collapse;
    background: var(--putih);
    border-radius: 8px; overflow: hidden;
    box-shadow: 0 2px 16px rgba(0,0,0,0.06);
  }
  .koleksi-table thead { background: var(--hijau); }
  .koleksi-table th {
    padding: 16px 20px; text-align: left;
    font-size: 12px; letter-spacing: 1px; text-transform: uppercase;
    color: rgba(255,255,255,0.85); font-weight: 600;
  }
  .koleksi-table td {
    padding: 16px 20px;
    border-bottom: 1px solid var(--krem-gelap);
    font-size: 14px; color: var(--hitam);
    vertical-align: middle;
  }
  .koleksi-table tr:last-child td { border-bottom: none; }
  .koleksi-table tr:hover td { background: rgba(26,92,56,0.04); }
  .badge {
    display: inline-block; padding: 3px 10px;
    border-radius: 12px; font-size: 11px; font-weight: 700; letter-spacing: 0.5px;
  }
  .badge-skripsi { background: #e8f4ec; color: var(--hijau); }
  .badge-tesis { background: #fef3e2; color: #a06800; }
  .badge-jurnal { background: #e8f0fe; color: #1a5cc8; }
  .badge-disertasi { background: #fce8e8; color: var(--merah); }
  .btn-lihat {
    background: transparent; border: 1.5px solid var(--hijau);
    color: var(--hijau); padding: 6px 14px;
    border-radius: 4px; font-size: 12px; font-weight: 600;
    cursor: pointer; transition: all 0.2s;
    font-family: 'Source Sans 3', sans-serif;
  }
  .btn-lihat:hover { background: var(--hijau); color: white; }

  /* === KONTAK === */
  #kontak { background: var(--putih); }
  .kontak-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; margin-top: 48px; }
  .kontak-info h3 { font-family: 'Playfair Display', serif; font-size: 24px; color: var(--hijau); margin-bottom: 24px; }
  .kontak-item {
    display: flex; gap: 16px;
    margin-bottom: 24px; align-items: flex-start;
  }
  .kontak-icon {
    width: 44px; height: 44px; flex-shrink: 0;
    background: var(--krem);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
  }
  .kontak-item h4 { font-size: 13px; font-weight: 700; color: var(--abu); letter-spacing: 0.5px; margin-bottom: 4px; }
  .kontak-item p { font-size: 15px; color: var(--hitam); line-height: 1.5; }

  .jam-layanan {
    background: var(--krem);
    border-radius: 8px;
    padding: 28px;
    margin-top: 32px;
  }
  .jam-layanan h4 { font-family: 'Playfair Display', serif; font-size: 18px; color: var(--hijau); margin-bottom: 16px; }
  .jam-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid var(--krem-gelap); font-size: 14px; }
  .jam-row:last-child { border-bottom: none; }
  .jam-row span:first-child { color: var(--abu); }
  .jam-row span:last-child { font-weight: 600; color: var(--hijau); }

  .map-placeholder {
    background: var(--krem);
    border-radius: 8px;
    height: 360px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    border: 2px dashed var(--krem-gelap);
    color: var(--abu);
    font-size: 14px; text-align: center;
  }
  .map-placeholder span { font-size: 48px; margin-bottom: 16px; }

  /* === FOOTER === */
  footer {
    background: var(--hitam);
    color: rgba(255,255,255,0.7);
    padding: 48px 80px;
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 20px;
  }
  footer .f-brand { font-family: 'Playfair Display', serif; font-size: 18px; color: var(--putih); margin-bottom: 6px; }
  footer p { font-size: 13px; }
  footer .f-links { display: flex; gap: 20px; flex-wrap: wrap; }
  footer .f-links a { color: rgba(255,255,255,0.5); text-decoration: none; font-size: 13px; transition: color 0.2s; }
  footer .f-links a:hover { color: var(--emas-muda); }

  /* === MODAL === */
  .modal-overlay {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(0,0,0,0.6);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s;
    backdrop-filter: blur(4px);
  }
  .modal-overlay.open { opacity: 1; pointer-events: all; }
  .modal {
    background: var(--putih);
    border-radius: 12px;
    max-width: 560px; width: 90%;
    padding: 48px;
    transform: translateY(20px);
    transition: transform 0.3s;
    position: relative;
    max-height: 90vh; overflow-y: auto;
  }
  .modal-overlay.open .modal { transform: translateY(0); }
  .modal-close {
    position: absolute; top: 20px; right: 20px;
    width: 32px; height: 32px;
    background: var(--krem);
    border: none; border-radius: 50%;
    cursor: pointer; font-size: 16px;
    display: flex; align-items: center; justify-content: center;
    color: var(--abu);
  }
  .modal h2 { font-family: 'Playfair Display', serif; font-size: 26px; color: var(--hijau); margin-bottom: 8px; }
  .modal p { color: var(--abu); font-size: 14px; margin-bottom: 24px; }
  .success-icon { font-size: 60px; text-align: center; margin-bottom: 16px; }

  /* === ANIMATIONS === */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .fade-in { animation: fadeUp 0.6s ease both; }

  /* === RESPONSIVE === */
  @media (max-width: 900px) {
    section { padding: 60px 24px; }
    nav { padding: 0 20px; }
    .nav-links { display: none; }
    .hero-content { padding: 60px 24px; }
    .hero-stats { position: static; padding: 0 24px 40px; flex-wrap: wrap; gap: 24px; }
    .upload-container, .kontak-grid { grid-template-columns: 1fr; }
    footer { padding: 40px 24px; flex-direction: column; text-align: center; }
  }
</style>
</head>
<body>

<!-- NAVBAR -->
<nav>
  <div class="nav-brand">
    <div class="nav-logo">RB</div>
    <div>
      <div class="nav-title">Ruang Baca Universitas Papua</div>
      <div class="nav-sub">Layanan Karya Ilmiah Digital</div>
    </div>
