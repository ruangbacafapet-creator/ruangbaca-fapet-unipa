    <div style="background:var(--krem); border-radius:6px; padding:10px 16px; margin-bottom:20px; font-family:'Courier Prime',monospace; font-size:12px; color:var(--hijau);">DETAIL KARYA ILMIAH</div>
    <h2 id="detailJudul" style="font-size:20px; line-height:1.4; margin-bottom:16px;"></h2>
    <table style="width:100%; border-collapse:collapse; font-size:14px;">
      <tr><td style="padding:8px 0; color:var(--abu); width:120px;">Penulis</td><td id="detailPenulis" style="font-weight:600;"></td></tr>
      <tr><td style="padding:8px 0; color:var(--abu);">Program Studi</td><td id="detailProdi" style="font-weight:600;"></td></tr>
      <tr><td style="padding:8px 0; color:var(--abu);">Tahun</td><td id="detailTahun" style="font-weight:600;"></td></tr>
      <tr><td style="padding:8px 0; color:var(--abu);">Status Akses</td><td><span style="background:#e8f4ec;color:var(--hijau);padding:3px 10px;border-radius:12px;font-size:12px;font-weight:700;">Open Access</span></td></tr>
    </table>
    <br>
    <button class="btn-submit" onclick="alert('Silakan hubungi Ruang Baca UNIPA untuk mengakses file lengkap.')">📥 Unduh PDF Lengkap</button>
  </div>
</div>

<script>
  function showFileName(input) {
    if (input.files && input.files[0]) {
      document.getElementById('fileName').textContent = '✓ ' + input.files[0].name;
    }
  }

  function submitForm() {
    const required = ['jenis','judul','nama','nim','prodi','tahun','keywords','abstrak','akses'];
    let empty = false;
    required.forEach(id => {
      const el = document.getElementById(id);
      if (!el.value) { el.style.borderColor = '#b53a2a'; empty = true; }
      else el.style.borderColor = '';
    });
    if (!document.getElementById('fileInput').files[0]) {
      alert('Harap upload file PDF karya ilmiah Anda.');
      return;
    }
    if (empty) { alert('Harap lengkapi semua bidang yang wajib diisi (*)'); return; }
    document.getElementById('successModal').classList.add('open');
  }

  function closeModal() {
    document.getElementById('successModal').classList.remove('open');
    ['jenis','judul','nama','nim','prodi','tahun','keywords','abstrak','akses'].forEach(id => {
      document.getElementById(id).value = '';
    });
    document.getElementById('fileInput').value = '';
    document.getElementById('fileName').textContent = '';
  }

  function showDetail(judul, penulis, tahun, prodi) {
    document.getElementById('detailJudul').textContent = judul;
    document.getElementById('detailPenulis').textContent = penulis;
    document.getElementById('detailProdi').textContent = prodi;
    document.getElementById('detailTahun').textContent = tahun;
    document.getElementById('detailModal').classList.add('open');
  }
  function closeDetailModal() { document.getElementById('detailModal').classList.remove('open'); }

  document.querySelectorAll('.modal-overlay').forEach(el => {
    el.addEventListener('click', function(e) { if (e.target === this) this.classList.remove('open'); });
  });

  let activeType = 'Semua';
  function filterByType(type, el) {
    activeType = type;
    document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
    filterTable();
  }

  function filterTable() {
    const q = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('#koleksiBody tr').forEach(row => {
      const text = row.textContent.toLowerCase();
      const typeMatch = activeType === 'Semua' || row.textContent.includes(activeType);
      row.style.display = (text.includes(q) && typeMatch) ? '' : 'none';
    });
  }
</script>
</body>
</html>
